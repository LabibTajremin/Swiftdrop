          "request": {
            "auth": { "type": "noauth" },
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/agents/{{agentMarcus}}/deliveries",
              "host": ["{{baseUrl}}"],
              "path": ["agents", "{{agentMarcus}}", "deliveries"]
            },
            "description": "Request with no x-api-key header. Must return 401."
